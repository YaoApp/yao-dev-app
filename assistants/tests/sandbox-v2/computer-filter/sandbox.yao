{
  "version": "2.0",
  "computer": {
    "image": "yaoapp/tai-sandbox-claude:latest",
    "memory": "2GB",
    "cpus": 2,
    "work_dir": "/workspace"
  },
  "runner": {
    "name": "claude",
    "mode": "cli",
    "options": {
      "max_turns": 5,
      "permission_mode": "bypassPermissions"
    }
  },
  "lifecycle": "session",
  "idle_timeout": "10m",
  "filter": {
    "kind": "box",
    "min_cpus": 2,
    "min_mem": "2GB"
  }
}
