{
  "version": "2.0",
  "computer": {
    "work_dir": "/tmp/yao-sandbox-v2-host-test"
  },
  "runner": {
    "name": "claude",
    "mode": "cli",
    "options": {
      "max_turns": 5,
      "permission_mode": "bypassPermissions"
    }
  },
  "lifecycle": "session",
  "idle_timeout": "10m",
  "prepare": [
    { "action": "exec", "cmd": "mkdir -p /tmp/yao-sandbox-v2-host-test", "once": true }
  ]
}
