{
  "label": "Claude Sonnet 4.0",
  "type": "openai",
  "options": {
    "model": "$ENV.CLAUDE_SONNET_4",
    "key": "$ENV.CLAUDE_API_KEY",
    "host": "$ENV.CLAUDE_API_HOST",
    "capabilities": {
      "vision": "claude",
      "tool_calls": true,
      "streaming": true,
      "json": true,
      "multimodal": true
    }
  }
}
