{
  "label": "OpenAI GPT-5 Nano",
  "type": "openai",
  "options": {
    "model": "gpt-5-nano",
    "key": "$ENV.OPENAI_API_KEY",
    "host": "$ENV.OPENAI_API_HOST",
    "capabilities": {
      "vision": true,
      "tool_calls": true,
      "reasoning": true,
      "streaming": true,
      "json": true,
      "multimodal": true
    }
  }
}
