{
  "label": "OpenAI GPT-4o-mini",
  "type": "openai",
  "options": {
    "model": "gpt-4o-mini",
    "key": "$ENV.OPENAI_API_KEY",
    "proxy": "$ENV.OPENAI_API_PROXY",
    "capabilities": {
      "vision": true,
      "tool_calls": true,
      "streaming": true,
      "json": true,
      "multimodal": true
    }
  }
}
