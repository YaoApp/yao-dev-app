{
  "label": "DeepSeek R1",
  "type": "openai",
  "options": {
    "model": "$ENV.DEEPSEEK_MODELS_R1",
    "key": "$ENV.DEEPSEEK_API_KEY",
    "proxy": "$ENV.DEEPSEEK_API_PROXY",
    "capabilities": {
      "reasoning": true,
      "streaming": true,
      "max_input_tokens": 65536,
      "max_output_tokens": 16384
    }
  }
}
