{
  "label": "DeepSeek V3",
  "type": "openai",
  "options": {
    "model": "$ENV.DEEPSEEK_MODELS_V3",
    "key": "$ENV.DEEPSEEK_API_KEY",
    "proxy": "$ENV.DEEPSEEK_API_PROXY",
    "capabilities": {
      "tool_calls": true,
      "streaming": true,
      "json": true,
      "max_input_tokens": 65536,
      "max_output_tokens": 16384
    }
  }
}
